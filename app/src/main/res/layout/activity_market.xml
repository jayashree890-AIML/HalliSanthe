<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Santhe"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/saffron"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="20dp"
            android:scaleType="centerCrop"
            android:src="@drawable/market"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KR Market, Bangalore"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/deepGreen"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Open Today • 8AM - 6PM"
            android:textSize="18sp"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Featured Products"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/saffron"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Fresh Mangoes\n• Handmade Pots\n• Traditional Sarees\n• Organic Vegetables"
            android:textSize="18sp"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="200+ villagers visited today"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/deepGreen"
            android:layout_marginTop="24dp"/>

    </LinearLayout>

</ScrollView>